# Discord bot token from the Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Your bot's application/client ID
CLIENT_ID=your_client_id_here

# Optional: restrict slash command registration to a single guild during development
GUILD_ID=

# Railway automatically sets this when a volume is attached.
# Leave blank for local development; the bot will fall back to ./data
RAILWAY_VOLUME_MOUNT_PATH=
