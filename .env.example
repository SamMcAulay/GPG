# Required: Discord bot token from the Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Optional: restrict slash command registration to a single guild.
# Use this for dev/test so commands appear instantly. Leave blank in prod
# to register commands globally.
GUILD_ID=

# Railway sets this automatically when a Volume is attached.
# Leave blank locally — the bot will fall back to ./data
RAILWAY_VOLUME_MOUNT_PATH=

# --- Battle.net integration (for /link and character display) ---

# Blizzard developer API client credentials from https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# Public base URL for the OAuth callback. On Railway, generate a public domain
# under Service Settings → Networking, then paste it here.
# Example: https://grey-parse-gary.up.railway.app
PUBLIC_BASE_URL=

# Optional Blizzard overrides (defaults shown match Retail — Midnight US)
# BLIZZARD_REGION=us
# BLIZZARD_PROFILE_NAMESPACE=profile-us
# BLIZZARD_LOCALE=en_US
# RAID_LEVEL=80

# Port for the OAuth callback server. Railway assigns this automatically.
PORT=3000
